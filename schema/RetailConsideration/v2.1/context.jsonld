    "BreakupType": "rccna:BreakupType",
    "LoyaltyPointsApplied": "rccna:LoyaltyPointsApplied",
    "paymentMethods": {
      "@id": "rccna:paymentMethods"
    },
    "currency": {
      "@id": "rccna:currency"
    },
    "breakup": {
      "@id": "rccna:breakup"
    },
    "breakupTitle": {
      "@id": "rccna:breakupTitle"
    },
    "breakupAmount": {
      "@id": "rccna:breakupAmount"
    },
    "breakupType": {
      "@id": "rccna:breakupType"
    },
    "totalAmount": {
