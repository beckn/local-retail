{
  "id": "https://schema.beckn.io/RetailConsideration/v2.1",
  "name": "Retail Consideration Attributes",
  "version": "2.1.0",
  "protocol_version": "2.0",
  "semantic_model": "generalised",
  "included_schemas": ["RetailConsideration"],
  "discovery_fields": [
    "paymentMethods",
    "totalAmount",
    "currency"
  ],
  "indexable_paths": [
    "beckn:considerationAttributes.paymentMethods",
    "beckn:considerationAttributes.currency",
    "beckn:considerationAttributes.totalAmount",
    "beckn:considerationAttributes.codAmount",
    "beckn:considerationAttributes.breakup[].type"
  ],
  "filterable_paths": [
    "beckn:considerationAttributes.paymentMethods",
    "beckn:considerationAttributes.currency",
    "beckn:considerationAttributes.codAmount"
  ],
  "sortable_paths": [
    "beckn:considerationAttributes.totalAmount"
  ],
  "privacy_notes": [
    "loyaltyPointsApplied.programId may identify a specific loyalty account",
    "appliedVouchers[].code may be single-use and should not be logged in plaintext"
  ]
}
