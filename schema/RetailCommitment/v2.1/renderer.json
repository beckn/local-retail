{
  "schema": "RetailCommitment",
  "version": "2.1.0",
  "card_template": "Line {{commitmentAttributes.lineId}} | Qty: {{commitmentAttributes.quantity.unitQuantity}} {{commitmentAttributes.quantity.unitCode}} | {{commitmentAttributes.price.currency}} {{commitmentAttributes.price.amount}}",
  "detail_template": "Line: {{commitmentAttributes.lineId}}\nResource: {{commitmentAttributes.resourceId}}\nOffer: {{commitmentAttributes.offerId}}\nQuantity: {{commitmentAttributes.quantity.unitQuantity}} {{commitmentAttributes.quantity.unitCode}}\nPrice: {{commitmentAttributes.price.currency}} {{commitmentAttributes.price.amount}}\nOriginal Price: {{commitmentAttributes.originalPrice}}\nAdd-Ons: {{commitmentAttributes.addOnIds}}\nInstructions: {{commitmentAttributes.specialInstructions}}",
  "html": "<div class=\"rccma-card\"><div class=\"rccma-line\"><code>{{commitmentAttributes.lineId}}</code></div><div class=\"rccma-qty\"><strong>{{commitmentAttributes.quantity.unitQuantity}}</strong> {{commitmentAttributes.quantity.unitCode}}</div><div class=\"rccma-price\">{{commitmentAttributes.price.currency}} {{commitmentAttributes.price.amount}}{{#if commitmentAttributes.originalPrice}} <s>{{commitmentAttributes.price.currency}} {{commitmentAttributes.originalPrice}}</s>{{/if}}</div>{{#if commitmentAttributes.specialInstructions}}<div class=\"rccma-note\"><em>{{commitmentAttributes.specialInstructions}}</em></div>{{/if}}</div>",
  "html_detail": "<div class=\"rccma-detail\"><section><h3>Commitment Reference</h3><p><strong>Line:</strong> <code>{{commitmentAttributes.lineId}}</code></p><p><strong>Resource:</strong> <code>{{commitmentAttributes.resourceId}}</code></p><p><strong>Offer:</strong> <code>{{commitmentAttributes.offerId}}</code></p></section><section><h3>Quantity</h3><p>{{commitmentAttributes.quantity.unitQuantity}} {{commitmentAttributes.quantity.unitCode}}</p></section><section><h3>Pricing</h3><p><strong>Amount:</strong> {{commitmentAttributes.price.currency}} {{commitmentAttributes.price.amount}}</p>{{#if commitmentAttributes.originalPrice}}<p><strong>Original Price:</strong> {{commitmentAttributes.price.currency}} {{commitmentAttributes.originalPrice}}</p>{{/if}}{{#if commitmentAttributes.price.estimatedValue}}<p><strong>Estimated:</strong> {{commitmentAttributes.price.estimatedValue}}</p>{{/if}}{{#if commitmentAttributes.price.maximumValue}}<p><strong>Maximum:</strong> {{commitmentAttributes.price.maximumValue}}</p>{{/if}}</section>{{#if commitmentAttributes.addOnIds}}<section><h3>Add-Ons</h3><p>{{commitmentAttributes.addOnIds}}</p></section>{{/if}}{{#if commitmentAttributes.selectedCustomizations}}<section><h3>Customizations</h3><ul>{{#each commitmentAttributes.selectedCustomizations}}<li>{{customizationLabel}}</li>{{/each}}</ul></section>{{/if}}{{#if commitmentAttributes.specialInstructions}}<section><h3>Special Instructions</h3><p>{{commitmentAttributes.specialInstructions}}</p></section>{{/if}}</div>"
}
