{
  "@context": {
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/",
    "rccma": "https://schema.beckn.io/RetailCommitment#",
    "@context": {
      "@id": "rccma:@context"
    },
    "@type": {
      "@id": "rccma:@type"
    },
    "CommitmentAttributes": "rccma:RetailCommitment",
    "RetailCommitment": "rccma:RetailCommitment",
    "lineId": {
      "@id": "rccma:lineId"
    },
    "resourceId": {
      "@id": "rccma:resourceId"
    },
    "offerId": {
      "@id": "rccma:offerId"
    },
    "quantity": {
      "@id": "rccma:quantity"
    },
    "unitCode": {
      "@id": "rccma:unitCode"
    },
    "unitQuantity": {
      "@id": "rccma:unitQuantity"
    },
    "price": {
      "@id": "rccma:price"
    },
    "originalPrice": {
      "@id": "rccma:originalPrice"
    },
    "addOnIds": {
      "@id": "rccma:addOnIds"
    },
    "selectedCustomizations": {
      "@id": "rccma:selectedCustomizations"
    },
    "customizationGroupId": {
      "@id": "rccma:customizationGroupId"
    },
    "customizationOptionId": {
      "@id": "rccma:customizationOptionId"
    },
    "customizationLabel": {
      "@id": "rccma:customizationLabel"
    },
    "specialInstructions": {
      "@id": "rccma:specialInstructions"
    }
  }
}
