{
  "@context": {
    "schema": "https://schema.org/",
    "beckn": "https://schema.beckn.io/",
    "rcsa": "https://schema.beckn.io/RetailSettlement#",
    "@context": {
      "@id": "rcsa:@context"
    },
    "@type": {
      "@id": "rcsa:@type"
    },
    "RetailSettlement": "rcsa:RetailSettlement",
    "SettlementMethod": "rcsa:SettlementMethod",
    "Gateway": "rcsa:Gateway",
    "gateway": {
      "@id": "rcsa:gateway"
    },
    "gatewayName": {
      "@id": "rcsa:gatewayName"
    },
    "gatewayTransactionId": {
      "@id": "rcsa:gatewayTransactionId"
    },
    "gatewayUrl": {
      "@id": "rcsa:gatewayUrl"
    },
    "method": {
      "@id": "rcsa:method"
    },
    "settledAt": {
      "@id": "rcsa:settledAt"
    },
    "settledAmount": {
      "@id": "rcsa:settledAmount"
    },
    "currency": {
      "@id": "rcsa:currency"
    },
    "paymentRail": {
      "@id": "rcsa:paymentRail"
    },
    "refund": {
      "@id": "rcsa:refund"
    },
    "refundAmount": {
      "@id": "rcsa:refundAmount"
    },
    "refundMethod": {
      "@id": "rcsa:refundMethod"
    },
    "refundTimelineDays": {
      "@id": "rcsa:refundTimelineDays"
    },
    "refundStatus": {
      "@id": "rcsa:refundStatus"
    },
    "adjustments": {
      "@id": "rcsa:adjustments"
    },
    "adjustmentType": {
      "@id": "rcsa:adjustmentType"
    },
    "adjustmentAmount": {
      "@id": "rcsa:adjustmentAmount"
    },
    "adjustmentDescription": {
      "@id": "rcsa:adjustmentDescription"
    },
    "reconciliationId": {
      "@id": "rcsa:reconciliationId"
    },
    "reconciliationStatus": {
      "@id": "rcsa:reconciliationStatus"
    }
  }
}
