{
  "@context": {
    "@import": "https://schema.beckn.io/core/v2/vocab.jsonld",
    "beckn": "https://schema.beckn.io/",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "schema": "https://schema.org/"
  },
  "@graph": [
    {
      "@id": "beckn:RetailSchemaPack",
      "@type": "owl:Ontology",
      "rdfs:label": "Beckn Retail Schema Pack v2.1",
      "rdfs:comment": "Unified ontology bridge for Retail Core and domain extensions in Beckn v2.1.",
      "owl:imports": [
        "https://schema.beckn.io/core/v2/vocab.jsonld",
        "https://schema.beckn.io/RetailResource/v2.1/vocab.jsonld",
        "https://schema.beckn.io/GroceryResource/v2.1/vocab.jsonld",
        "https://schema.beckn.io/FoodAndBeverageResource/v2.1/vocab.jsonld",
        "https://schema.beckn.io/HomeAndKitchenResource/v2.1/vocab.jsonld",
        "https://schema.beckn.io/RetailOffer/v2.1/vocab.jsonld",
        "https://schema.beckn.io/FoodAndBeverageOffer/v2.1/vocab.jsonld",
        "https://schema.beckn.io/RetailPerformance/v2.1/vocab.jsonld",
        "https://schema.beckn.io/RetailContract/v2.1/vocab.jsonld",
        "https://schema.beckn.io/RetailCommitment/v2.1/vocab.jsonld",
        "https://schema.beckn.io/RetailConsideration/v2.1/vocab.jsonld",
        "https://schema.beckn.io/RetailSettlement/v2.1/vocab.jsonld"
      ]
    },
    {
      "@id": "beckn:RetailCoreSchema",
      "@type": "rdfs:Class",
      "rdfs:label": "Retail Core Schema",
      "rdfs:comment": "Cross-vertical base schemas used across all retail sub-domains."
    },
    {
      "@id": "beckn:RetailDomainExtensionSchema",
      "@type": "rdfs:Class",
      "rdfs:label": "Retail Domain Extension Schema",
      "rdfs:comment": "Sub-vertical schemas extending the retail core."
    },
    {
      "@id": "beckn:extendsSchema",
      "@type": "rdf:Property",
      "rdfs:label": "extends schema",
      "rdfs:comment": "Links an extension schema to the core schema it extends.",
      "rdfs:domain": "beckn:RetailDomainExtensionSchema",
      "rdfs:range": "beckn:RetailCoreSchema"
    },
    {
      "@id": "beckn:container",
      "@type": "rdf:Property",
      "rdfs:label": "container",
      "rdfs:comment": "Container slot in Beckn generalized payload where this schema applies.",
      "rdfs:range": "xsd:string"
    },
    {
      "@id": "beckn:RetailResource",
      "@type": [
        "rdfs:Class",
        "beckn:RetailCoreSchema"
      ],
      "rsp:container": "resourceAttributes"
    },
    {
      "@id": "beckn:RetailOffer",
      "@type": [
        "rdfs:Class",
        "beckn:RetailCoreSchema"
      ],
      "rsp:container": "offerAttributes"
    },
    {
      "@id": "beckn:PerformanceAttributes",
      "@type": [
        "rdfs:Class",
        "beckn:RetailCoreSchema"
      ],
      "rsp:container": "performanceAttributes"
    },
    {
      "@id": "beckn:ContractAttributes",
      "@type": [
        "rdfs:Class",
        "beckn:RetailCoreSchema"
      ],
      "rsp:container": "contractAttributes"
    },
    {
      "@id": "beckn:RetailCommitment",
      "@type": [
        "rdfs:Class",
        "beckn:RetailCoreSchema"
      ],
      "rsp:container": "commitmentAttributes",
      "owl:equivalentClass": "beckn:CommitmentAttributes"
    },
    {
      "@id": "beckn:RetailConsideration",
      "@type": [
        "rdfs:Class",
        "beckn:RetailCoreSchema"
      ],
      "rsp:container": "considerationAttributes"
    },
    {
      "@id": "beckn:RetailSettlement",
      "@type": [
        "rdfs:Class",
        "beckn:RetailCoreSchema"
      ],
      "rsp:container": "settlementAttributes"
    },
    {
      "@id": "beckn:GroceryResourceAttributes",
      "@type": [
        "rdfs:Class",
        "beckn:RetailDomainExtensionSchema"
      ],
      "rdfs:subClassOf": "beckn:RetailResource",
      "rsp:extendsSchema": "beckn:RetailResource",
      "rsp:container": "resourceAttributes"
    },
    {
      "@id": "beckn:FoodAndBeverageResourceAttributes",
      "@type": [
        "rdfs:Class",
        "beckn:RetailDomainExtensionSchema"
      ],
      "rdfs:subClassOf": "beckn:RetailResource",
      "rsp:extendsSchema": "beckn:RetailResource",
      "rsp:container": "resourceAttributes"
    },
    {
      "@id": "beckn:HomeAndKitchenResourceAttributes",
      "@type": [
        "rdfs:Class",
        "beckn:RetailDomainExtensionSchema"
      ],
      "rdfs:subClassOf": "beckn:RetailResource",
      "rsp:extendsSchema": "beckn:RetailResource",
      "rsp:container": "resourceAttributes"
    },
    {
      "@id": "beckn:FoodAndBeverageOfferAttributes",
      "@type": [
        "rdfs:Class",
        "beckn:RetailDomainExtensionSchema"
      ],
      "rdfs:subClassOf": "beckn:RetailOffer",
      "rsp:extendsSchema": "beckn:RetailOffer",
      "rsp:container": "offerAttributes"
    },
    {
      "@id": "beckn:breakupTitle",
      "owl:equivalentProperty": "beckn:title"
    },
    {
      "@id": "beckn:breakupAmount",
      "owl:equivalentProperty": "beckn:amount"
    },
    {
      "@id": "beckn:breakupType",
      "owl:equivalentProperty": "beckn:type"
    },
    {
      "@id": "beckn:gatewayName",
      "owl:equivalentProperty": "beckn:name"
    },
    {
      "@id": "beckn:gatewayTransactionId",
      "owl:equivalentProperty": "beckn:transactionId"
    },
    {
      "@id": "beckn:gatewayUrl",
      "owl:equivalentProperty": "beckn:url"
    },
    {
      "@id": "beckn:daysOfWeek",
      "owl:equivalentProperty": "beckn:daysOfWeek"
    },
    {
      "@id": "beckn:timeRange",
      "owl:equivalentProperty": "beckn:timeRange"
    },
    {
      "@id": "beckn:currency",
      "owl:equivalentProperty": "beckn:currency"
    },
    {
      "@id": "beckn:installationNotes",
      "skos:relatedMatch": "beckn:installationNotes"
    }
  ]
}
